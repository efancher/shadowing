{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://efancher.github.io/shadowing/schemas/shadowing-package.schema.json",
  "title": "Japanese Shadowing Package",
  "description": "Versioned portable package produced by shadowmine and imported by the practice web app.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest", "source", "sentences"],
  "properties": {
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "version", "createdAt", "generator"],
      "properties": {
        "format": { "const": "japanese-shadowing-package" },
        "version": { "const": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["youtube", "uploaded-video", "uploaded-audio", "podcast", "manual", "other"]
        },
        "url": { "type": "string" },
        "videoId": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "channel": { "type": "string" },
        "durationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "sentences": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sentence" }
    },
    "subtitlePath": {
      "type": "string",
      "description": "Optional relative path to a packaged subtitle file such as subtitles/ja.vtt"
    }
  },
  "$defs": {
    "sentence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "japanese",
        "startMs",
        "endMs",
        "transcriptStatus",
        "tags",
        "audio"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "japanese": { "type": "string", "minLength": 1 },
        "reading": { "type": "string" },
        "english": { "type": "string" },
        "startMs": { "type": "integer", "minimum": 0 },
        "endMs": { "type": "integer", "minimum": 1 },
        "subtitleStartMs": { "type": "integer", "minimum": 0 },
        "subtitleEndMs": { "type": "integer", "minimum": 1 },
        "adjustedStartMs": { "type": "integer", "minimum": 0 },
        "adjustedEndMs": { "type": "integer", "minimum": 1 },
        "speaker": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "notes": { "type": "string" },
        "transcriptStatus": {
          "type": "string",
          "enum": ["unverified", "auto-caption", "manually-corrected", "verified"]
        },
        "audio": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "mimeType", "durationMs"],
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^audio/[^/]+\\.(m4a|mp4|aac|wav)$"
            },
            "mimeType": {
              "type": "string",
              "enum": ["audio/mp4", "audio/aac", "audio/wav", "audio/x-m4a"]
            },
            "durationMs": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
